{
	"name": "@soorya-u/better-auth-electrobun",
	"version": "0.1.0",
	"description": "Better Auth client integration for Electrobun desktop apps. Reuses the framework-agnostic server plugin and web proxy from @better-auth/electron.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/soorya-u/better-auth-electrobun",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/soorya-u/better-auth-electrobun.git"
	},
	"keywords": [
		"electrobun",
		"auth",
		"better-auth",
		"desktop",
		"typescript"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint:package": "publint run --strict --pack false",
		"lint:types": "attw --profile esm-only --pack .",
		"typecheck": "tsc --project tsconfig.typecheck.json --noEmit",
		"test": "vitest",
		"coverage": "vitest run --coverage --coverage.provider=istanbul",
		"check": "biome check",
		"fix": "biome check --fix --assist-enabled=true"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"dev-source": "./src/index.ts",
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./server": {
			"dev-source": "./src/server/index.ts",
			"types": "./dist/server/index.d.mts",
			"default": "./dist/server/index.mjs"
		},
		"./client": {
			"dev-source": "./src/client.ts",
			"types": "./dist/client.d.mts",
			"default": "./dist/client.mjs"
		},
		"./callback": {
			"dev-source": "./src/callback.ts",
			"types": "./dist/callback.d.mts",
			"default": "./dist/callback.mjs"
		},
		"./storage": {
			"dev-source": "./src/storage.ts",
			"types": "./dist/storage.d.mts",
			"default": "./dist/storage.mjs"
		},
		"./rpc/webview": {
			"dev-source": "./src/rpc/webview.ts",
			"types": "./dist/rpc/webview.d.mts",
			"default": "./dist/rpc/webview.mjs"
		}
	},
	"typesVersions": {
		"*": {
			"*": [
				"./dist/index.d.mts"
			],
			"server": [
				"./dist/server/index.d.mts"
			],
			"client": [
				"./dist/client.d.mts"
			],
			"callback": [
				"./dist/callback.d.mts"
			],
			"storage": [
				"./dist/storage.d.mts"
			],
			"rpc/webview": [
				"./dist/rpc/webview.d.mts"
			]
		}
	},
	"dependencies": {
		"@better-auth/electron": "^1.6.21",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "latest",
		"better-auth": "^1.6.21",
		"better-call": "1.3.7",
		"better-sqlite3": "^12.11.1",
		"electrobun": "^1.18.1",
		"publint": "^0.3.12",
		"tsdown": "^0.21.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"@better-auth/core": "^1.6.21",
		"@better-auth/utils": "^0.4.2",
		"@better-fetch/fetch": "^1.3.1",
		"better-auth": "^1.6.21",
		"better-call": "^1.3.7",
		"electrobun": ">=1.18.1"
	},
	"peerDependenciesMeta": {
		"electrobun": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
